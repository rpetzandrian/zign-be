{
  "name": "zign-be",
  "version": "0.0.1",
  "description": "Esign App",
  "main": "index.ts",
  "scripts": {
    "start": "nodemon",
    "dev": "nodemon src/app.ts",
    "clean-install": "rm -rf node_modules package-lock.json && npm install",
    "build": "rm -rf ./build && ./node_modules/typescript/bin/tsc",
    "test": "NODE_ENV=test nyc ava --verbose"
  },
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@aws-sdk/client-s3": "^3.901.0",
    "@aws-sdk/lib-storage": "^3.903.0",
    "@prisma/client": "~6.17.0",
    "amqplib": "^0.10.9",
    "axios": "^1.13.2",
    "bcrypt": "^6.0.0",
    "canvas": "^2.11.2",
    "date-fns": "^4.1.0",
    "dotenv": "^17.2.2",
    "express": "^5.1.0",
    "handlebars": "^4.7.8",
    "http-status-codes": "^2.3.0",
    "joi": "^18.0.1",
    "jsdom": "^21.1.2",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.0.2",
    "node-poppler": "^8.0.5",
    "nodemailer": "^7.0.6",
    "openai": "^5.23.1",
    "pdf-lib": "^1.17.1",
    "qr-code-styling": "^1.9.2",
    "uuid": "^8.3.2",
    "winston": "^3.17.0"
  },
  "devDependencies": {
    "@types/amqplib": "^0.10.7",
    "@types/bcrypt": "^6.0.0",
    "@types/express": "^5.0.3",
    "@types/jsdom": "^21.1.1",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.0.0",
    "@types/node": "^24.5.2",
    "@types/nodemailer": "^7.0.1",
    "@types/qrcode": "^1.5.6",
    "@types/sinon": "^21.0.0",
    "@types/uuid": "^8.3.4",
    "ava": "^6.4.1",
    "nodemon": "^3.1.10",
    "nyc": "^17.1.0",
    "prisma": "~6.17.0",
    "sinon": "^21.0.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.2"
  },
  "ava": {
    "extensions": [
      "ts"
    ],
    "require": [
      "ts-node/register/transpile-only"
    ],
    "files": [
      "./tests/**/*.test.ts"
    ],
    "timeout": "1m",
    "workerThreads": false,
    "nodeArguments": [
      "--loader=ts-node/esm",
      "--no-warnings"
    ]
  }
}
